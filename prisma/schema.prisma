// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PortfolioSection {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  type      String
  navTitle  String
  data      Json
  updatedAt DateTime @updatedAt
}
